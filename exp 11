#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int sstf(int req[], int n, int head) {
    int total = 0, visited[10] = {0}, count = 0, current = head;

    while (count < n) {
        int min = 10000, index = -1;
        for (int i = 0; i < n; i++) {
            if (!visited[i]) {
                int dist = abs(req[i] - current);
                if (dist < min) {
                    min = dist;
                    index = i;
                }
            }
        }
        visited[index] = 1;
        total += abs(req[index] - current);
        current = req[index];
        count++;
    }
    return total;
}

int look(int req[], int n, int head) {
    int total = 0, current = head;

    int sorted[10];
    for (int i = 0; i < n; i++) sorted[i] = req[i];

    for (int i = 0; i < n - 1; i++)
        for (int j = 0; j < n - i - 1; j++)
            if (sorted[j] > sorted[j + 1]) {
                int temp = sorted[j];
                sorted[j] = sorted[j + 1];
                sorted[j + 1] = temp;
            }

    int i;
    for (i = 0; i < n; i++)
        if (sorted[i] >= head) break;

    for (int j = i; j < n; j++) {
        total += abs(sorted[j] - current);
        current = sorted[j];
    }

    for (int j = i - 1; j >= 0; j--) {
        total += abs(sorted[j] - current);
        current = sorted[j];
    }

    return total;
}

int cscan(int req[], int n, int head) {
    int total = 0, current = head, max = 4999;

    int sorted[10];
    for (int i = 0; i < n; i++) sorted[i] = req[i];

    for (int i = 0; i < n - 1; i++)
        for (int j = 0; j < n - i - 1; j++)
            if (sorted[j] > sorted[j + 1]) {
                int temp = sorted[j];
                sorted[j] = sorted[j + 1];
                sorted[j + 1] = temp;
            }

    int i;
    for (i = 0; i < n; i++)
        if (sorted[i] >= head) break;

    for (int j = i; j < n; j++) {
        total += abs(sorted[j] - current);
        current = sorted[j];
    }

    total += abs(max - current);
    current = max;

    total += max;
    current = 0;

    for (int j = 0; j < i; j++) {
        total += abs(sorted[j] - current);
        current = sorted[j];
    }

    return total;
}

int main(int argc, char *argv[]) {
    if (argc != 2) {
        printf("Usage: %s <initial_head>\n", argv[0]);
        return 0;
    }

    int head = atoi(argv[1]);
    int req[10];

    srand(time(0));

    for (int i = 0; i < 10; i++) {
        req[i] = rand() % 5000;
    }

    printf("Requests: ");
    for (int i = 0; i < 10; i++) printf("%d ", req[i]);

    printf("\nInitial Head: %d\n", head);

    printf("SSTF: %d\n", sstf(req, 10, head));
    printf("LOOK: %d\n", look(req, 10, head));
    printf("C-SCAN: %d\n", cscan(req, 10, head));

    return 0;
}
