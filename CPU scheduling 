#include <stdio.h>
#include <limits.h>
#define MAX 50
#define QUANTUM 4
typedef struct {
 int pid;
 int arrival;
 int burst;
 int remaining;
 int priority;
 int completion;
 int waiting;
 int turnaround;
} Process;
void copyProcesses(Process dest[], Process src[], int n) {
 for(int i = 0; i < n; i++)
 dest[i] = src[i];
}
float fcfs(Process p[], int n) {
 int time = 0;
 float total_wait = 0;
 for(int i = 0; i < n-1; i++)
  for(int j = i+1; j < n; j++)
 if(p[i].arrival > p[j].arrival) {
 Process temp = p[i];
 p[i] = p[j];
 p[j] = temp;
 }
 for(int i = 0; i < n; i++) {
 if(time < p[i].arrival)
 time = p[i].arrival;
 p[i].waiting = time - p[i].arrival;
 time += p[i].burst;
 total_wait += p[i].waiting;
 }
 return total_wait / n;
}
float sjf(Process p[], int n) {
 int completed = 0, time = 0;
 int visited[MAX] = {0};
 float total_wait = 0;
 while(completed < n) {
 int idx = -1;
 int min_burst = INT_MAX;
 for(int i = 0; i < n; i++) {
 if(!visited[i] && p[i].arrival <= time && p[i].burst < min_burst) {
 min_burst = p[i].burst;
 idx = i;
 }
 }
 if(idx == -1) {
 time++;
 } else {
 p[idx].waiting = time - p[idx].arrival;
 time += p[idx].burst;
 total_wait += p[idx].waiting;
 visited[idx] = 1;
 completed++;
 }
 }
 return total_wait / n;
}
float priority_non_preemptive(Process p[], int n) {
 int completed = 0, time = 0;
 int visited[MAX] = {0};
 float total_wait = 0;
 while(completed < n) {
 int idx = -1;
 int highest_priority = -1;
 for(int i = 0; i < n; i++) {
 if(!visited[i] && p[i].arrival <= time &&
 p[i].priority > highest_priority) {
 highest_priority = p[i].priority;
 idx = i;
 }
 }
 if(idx == -1) {
 time++;
 } else {
 p[idx].waiting = time - p[idx].arrival;
 time += p[idx].burst;
 total_wait += p[idx].waiting;
 visited[idx] = 1;
 completed++;
 }
 }
 return total_wait / n;
}
float round_robin(Process p[], int n) {
int time = 0, completed = 0;
 float total_wait = 0;
 for(int i = 0; i < n; i++)
 p[i].remaining = p[i].burst;
 while(completed < n) {
 int done = 1;
 for(int i = 0; i < n; i++) {
 if(p[i].remaining > 0 && p[i].arrival <= time) {
 done = 0;
 if(p[i].remaining > QUANTUM) {
 time += QUANTUM;
 p[i].remaining -= QUANTUM;
 } else {
 time += p[i].remaining;
 p[i].waiting = time - p[i].arrival - p[i].burst;
 total_wait += p[i].waiting;
 p[i].remaining = 0;
 completed++;
 }
 }
 }
  if(done)
    time++;
 }
 return total_wait / n;
}
int main() {
 int n;
 Process processes[MAX], temp[MAX];
 printf("Enter number of processes: ");
 scanf("%d", &n);
 for(int i = 0; i < n; i++) {
 processes[i].pid = i+1;
 printf("\nProcess P%d\n", i+1);
 printf("Arrival Time: ");
 scanf("%d", &processes[i].arrival);
 printf("Burst Time: ");
 scanf("%d", &processes[i].burst);
 printf("Priority: ");
 scanf("%d", &processes[i].priority);
 }
 copyProcesses(temp, processes, n);
 float fcfs_avg = fcfs(temp, n);
 copyProcesses(temp, processes, n);
 float sjf_avg = sjf(temp, n);
 copyProcesses(temp, processes, n);
 float priority_avg = priority_non_preemptive(temp, n);
 copyProcesses(temp, processes, n);
 float rr_avg = round_robin(temp, n);
 printf("\nAverage Waiting Time:\n");
 printf("FCFS = %.2f\n", fcfs_avg);
 printf("SJF = %.2f\n", sjf_avg);
 printf("Priority = %.2f\n", priority_avg);
 printf("Round Robin (q=4) = %.2f\n", rr_avg);
 float min = fcfs_avg;
 char best[20] = "FCFS";
 if(sjf_avg < min) {
 min = sjf_avg;
 sprintf(best, "SJF");
 }
 if(priority_avg < min) {
 min = priority_avg;
 sprintf(best, "Priority");
 }
 if(rr_avg < min) {
 min = rr_avg;
 sprintf(best, "Round Robin");
 }
 printf("\nAlgorithm with Minimum Average Waiting Time: %s\n", best);
 return 0;
}
